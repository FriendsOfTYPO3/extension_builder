{
    "name": "acmecorp/eb-astrophotography",
    "type": "typo3-cms-extension",
    "description": "",
    "authors": [],
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "typo3/cms-core": "^14.0"
    },
    "require-dev": {
        "typo3/testing-framework": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "AcmeCorp\\EbAstrophotography\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AcmeCorp\\EbAstrophotography\\Tests\\": "Tests"
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin"
    },
    "scripts": {
        "post-autoload-dump": [
            "TYPO3\\TestingFramework\\Composer\\ExtensionTestEnvironment::prepare"
        ]
    },
    "extra": {
        "typo3/cms": {
            "web-dir": ".Build/public",
            "extension-key": "eb_astrophotography"
        }
    }
}