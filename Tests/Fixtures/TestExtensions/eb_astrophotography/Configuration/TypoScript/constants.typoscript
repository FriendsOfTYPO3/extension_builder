plugin.tx_ebastrophotography_imagegallery {
    view {
        # cat=plugin.tx_ebastrophotography_imagegallery/file; type=string; label=Path to template root (FE)
        templateRootPath = EXT:eb_astrophotography/Resources/Private/Templates/
        # cat=plugin.tx_ebastrophotography_imagegallery/file; type=string; label=Path to template partials (FE)
        partialRootPath = EXT:eb_astrophotography/Resources/Private/Partials/
        # cat=plugin.tx_ebastrophotography_imagegallery/file; type=string; label=Path to template layouts (FE)
        layoutRootPath = EXT:eb_astrophotography/Resources/Private/Layouts/
    }
    persistence {
        # cat=plugin.tx_ebastrophotography_imagegallery//a; type=string; label=Default storage PID
        storagePid =
    }
}
