plugin.tx_ebastrophotography_imagegallery {
    view {
        templateRootPaths.0 = EXT:eb_astrophotography/Resources/Private/Templates/
        templateRootPaths.1 = {$plugin.tx_ebastrophotography_imagegallery.view.templateRootPath}
        partialRootPaths.0 = EXT:eb_astrophotography/Resources/Private/Partials/
        partialRootPaths.1 = {$plugin.tx_ebastrophotography_imagegallery.view.partialRootPath}
        layoutRootPaths.0 = EXT:eb_astrophotography/Resources/Private/Layouts/
        layoutRootPaths.1 = {$plugin.tx_ebastrophotography_imagegallery.view.layoutRootPath}
    }
    persistence {
        storagePid = {$plugin.tx_ebastrophotography_imagegallery.persistence.storagePid}
        #recursive = 1
    }
    features {
        #skipDefaultArguments = 1
        # if set to 1, the enable fields are ignored in BE context
        ignoreAllEnableFieldsInBe = 0
    }
    mvc {
        #callDefaultActionIfActionCantBeResolved = 1
    }
}
