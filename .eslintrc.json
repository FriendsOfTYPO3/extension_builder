{
    "env": {
        "browser": true,
        "es6": true
    },
    "globals": {
        "YAHOO": "readonly",
        "TYPO3": "readonly",
        "extbaseModeling_wiringEditorLanguage": "readonly"
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": ["warn"],
        "no-console": ["warn"],
        "eqeqeq": ["error", "always"],
        "curly": ["error", "all"]
    },
    "ignorePatterns": [
        ".Build/",
        "node_modules/",
        "Resources/Public/jsDomainModeling/wireit/"
    ]
}
