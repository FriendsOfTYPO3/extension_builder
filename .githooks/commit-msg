#!/usr/bin/env bash
#
# commit-msg hook: Validates commit messages against TYPO3 conventions.
# Reference: https://docs.typo3.org/m/typo3/guide-contributionworkflow/main/en-us/Appendix/CommitMessage.html
#
# Adapted for extension_builder (GitHub-based, no Gerrit Change-Id needed).

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits
if echo "$COMMIT_MSG" | head -1 | grep -qE "^Merge "; then
    exit 0
fi

ERRORS=()

# --- Subject line validation ---

SUBJECT=$(echo "$COMMIT_MSG" | head -1)

# Check keyword prefix: optional [!!!], optional [WIP]/[POC], then required type keyword
TYPES='BUGFIX|FEATURE|TASK|DOCS|RELEASE|DEVBOX'
KEYWORD_PATTERN="^(\[!!!\] )?(\[(WIP|POC)\] )?\[(${TYPES})\] .+"
if ! echo "$SUBJECT" | grep -qE "$KEYWORD_PATTERN"; then
    ERRORS+=("Subject must start with [BUGFIX], [FEATURE], [TASK], [DOCS], [RELEASE], or [DEVBOX]")
    ERRORS+=("  Optional prefixes: [!!!] for breaking changes, [WIP]/[POC] for drafts")
    ERRORS+=("  Example: [TASK] Add commit message validation hook")
fi

# Check subject length (max 72 chars)
SUBJECT_LEN=${#SUBJECT}
if [ "$SUBJECT_LEN" -gt 72 ]; then
    ERRORS+=("Subject line is $SUBJECT_LEN chars — maximum is 72")
fi

# Check capital letter after keyword (match the last [...] TYPE bracket, then check next char)
if echo "$SUBJECT" | grep -qE "\[(${TYPES})\] [a-z]"; then
    ERRORS+=("Subject must start with a capital letter after the keyword prefix")
fi

# Check no period at the end
if echo "$SUBJECT" | grep -qE '\.$'; then
    ERRORS+=("Subject must not end with a period")
fi

# --- Body validation ---

LINE_NUM=0
while IFS= read -r LINE; do
    LINE_NUM=$((LINE_NUM + 1))

    # Skip subject line
    [ "$LINE_NUM" -eq 1 ] && continue

    # Second line must be blank (separator between subject and body)
    if [ "$LINE_NUM" -eq 2 ] && [ -n "$LINE" ]; then
        ERRORS+=("Line 2 must be blank (separate subject from body with an empty line)")
        continue
    fi

    # Skip blank lines, footer lines (Resolves:, Related:, Co-Authored-By:, etc.), and URLs
    if [ -z "$LINE" ]; then
        continue
    fi
    if echo "$LINE" | grep -qE '^(Resolves|Related|Releases|Depends|Reverts|Co-Authored-By|Change-Id):'; then
        continue
    fi

    # Check body line length (max 72 chars, allow URLs as exception)
    LINE_LEN=${#LINE}
    if [ "$LINE_LEN" -gt 72 ]; then
        if ! echo "$LINE" | grep -qE 'https?://'; then
            ERRORS+=("Line $LINE_NUM is $LINE_LEN chars — body lines should wrap at 72 chars")
        fi
    fi
done <<< "$COMMIT_MSG"

# --- Report errors ---

if [ ${#ERRORS[@]} -gt 0 ]; then
    echo ""
    echo "========================================="
    echo "  COMMIT MESSAGE VALIDATION FAILED"
    echo "========================================="
    echo ""
    echo "Your commit message:"
    echo "---"
    echo "$SUBJECT"
    echo "---"
    echo ""
    echo "Problems found:"
    for ERR in "${ERRORS[@]}"; do
        echo "  - $ERR"
    done
    echo ""
    echo "TYPO3 commit message format:"
    echo "  [TYPE] Summary in imperative mood (max 72 chars)"
    echo ""
    echo "  Optional body wrapped at 72 chars."
    echo ""
    echo "  Resolves: #<GitHub-Issue-Number>"
    echo ""
    echo "Allowed types: [BUGFIX] [FEATURE] [TASK] [DOCS] [RELEASE] [DEVBOX]
Draft prefixes: [WIP] [POC]"
    echo "Breaking change prefix: [!!!] [TYPE] ..."
    echo ""
    echo "Reference: https://docs.typo3.org/m/typo3/guide-contributionworkflow/main/en-us/Appendix/CommitMessage.html"
    echo "========================================="
    exit 1
fi
